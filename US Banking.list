# === US Banks 专属分流规则 ===
# 适用于 Shadowrocket (小火箭) 外部规则集
# 说明：在小火箭添加此规则集后，请将策略统一指向你的美国家宽节点

# =========================================
# === Capital One ===
# =========================================
# Capital One 主域名及信用卡专属域名
DOMAIN-SUFFIX,capitalone.com
DOMAIN-SUFFIX,capitalonecards.com
# Capital One 国际域名（防止 App 内部重定向导致 IP 泄露）
DOMAIN-SUFFIX,capitalone.ca
DOMAIN-SUFFIX,capitalone.co.uk
# 关键词兜底匹配
DOMAIN-KEYWORD,capitalone
# 银行及信用卡常用的第三方安全证书验证域名
DOMAIN-SUFFIX,entrust.net

# =========================================
# === Credit Bureaus (三大信用局) ===
# =========================================
# Equifax (最常用的信用分数查询)
DOMAIN-SUFFIX,equifax.com
DOMAIN-SUFFIX,equifax.ca
DOMAIN-KEYWORD,equifax
# Experian (信用报告)
DOMAIN-SUFFIX,experian.com
DOMAIN-SUFFIX,experian.co.uk
DOMAIN-SUFFIX,expn.com
DOMAIN-KEYWORD,experian
# TransUnion
DOMAIN-SUFFIX,transunion.com
DOMAIN-SUFFIX,truelink.com
DOMAIN-KEYWORD,transunion

# =========================================
# === American Express (美国运通) ===
# =========================================
DOMAIN-SUFFIX,americanexpress.com
DOMAIN-SUFFIX,aexp-static.com
DOMAIN-SUFFIX,amexnetwork.com
DOMAIN-KEYWORD,americanexpress
DOMAIN-KEYWORD,amex

# =========================================
# === Chase (摩根大通) ===
# =========================================
DOMAIN-SUFFIX,chase.com
DOMAIN-SUFFIX,chasecdn.com
DOMAIN-SUFFIX,chaseonline.chase.com
DOMAIN-KEYWORD,chase

# =========================================
# === Citibank (花旗) ===
# =========================================
DOMAIN-SUFFIX,citi.com
DOMAIN-SUFFIX,citibank.com
DOMAIN-SUFFIX,citigroup.com
DOMAIN-KEYWORD,citi

# =========================================
# === 其他主流美卡银行 (BofA, Discover, Wells Fargo) ===
# =========================================
# Bank of America (美国银行)
DOMAIN-SUFFIX,bankofamerica.com
DOMAIN-SUFFIX,bofa.com
# Discover (发现卡)
DOMAIN-SUFFIX,discover.com
DOMAIN-SUFFIX,discovercard.com
# Wells Fargo (富国银行)
DOMAIN-SUFFIX,wellsfargo.com
DOMAIN-SUFFIX,wellsfargoadvisors.com
# US Bank
DOMAIN-SUFFIX,usbank.com

# =========================================
# === Fintech & Rewards (常用金融及返现) ===
# =========================================
# SoFi (fintech银行)
DOMAIN-SUFFIX,sofi.com
DOMAIN-SUFFIX,sofi.io
DOMAIN-SUFFIX,sofi.org
DOMAIN-KEYWORD,sofi
# Bilt Rewards (房租神卡)
DOMAIN-SUFFIX,biltrewards.com
DOMAIN-SUFFIX,bilt.com
# Rakuten (常用返现)
DOMAIN-SUFFIX,rakuten.com
# Venmo (美区常用转账)
DOMAIN-SUFFIX,venmo.com
# Zelle (银行间转账)
DOMAIN-SUFFIX,zellepay.com

# =========================================
# === 银行及身份验证基础设施 ===
# =========================================
# Plaid (强烈建议保留，美国银行间互相绑卡、验证、出入金时必用的网关接口)
DOMAIN-SUFFIX,plaid.com
# Persona (开卡时的真人身份验证)
DOMAIN-SUFFIX,withpersona.com
